---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroPainter from '../components/sections/HeroPainter.astro';
import ServicesGrid from '../components/sections/ServicesGrid.astro';
import WhyUs from '../components/sections/WhyUs.astro';
import ProcessSteps from '../components/sections/ProcessSteps.astro';
import AreaCoverage from '../components/sections/AreaCoverage.astro';
import ContactCta from '../components/sections/ContactCta.astro';
import Section from '../components/ui/Section.astro';
import RevealContact from '../components/ui/RevealContact.astro';
import { seo } from '../data/seo';
import { site } from '../data/site';
---

<BaseLayout title={seo.home.title} description={seo.home.description}>
  <HeroPainter />

  <Section>
    <div class="grid gap-4 lg:grid-cols-[1.1fr_0.9fr]">
      <div class="rounded-4xl border border-black/5 bg-white p-6 shadow-soft md:p-7">
        <h2 class="text-2xl font-black md:text-3xl">Koho vlastně voláte</h2>
        <p class="mt-4 max-w-2xl text-lg leading-8 text-black/80">
          Martin Ondroušek a Dušan Klas. Řemeslná firma s adresou {site.streetAddress}, {site.city}. Na webu
          necháváme vše jednoduše, protože nejrychlejší domluva je po telefonu.
        </p>
      </div>
      <div class="rounded-4xl bg-brand-yellow/20 p-6 ring-1 ring-black/5 md:p-7">
        <p class="text-sm font-semibold uppercase tracking-wide text-black/55">Rychlý kontakt</p>
        <p class="mt-3 text-xl font-black leading-snug text-brand-ink">Potřebujete malíře pro Přerovsko nebo širší okolí?</p>
        <div class="mt-5 flex flex-wrap items-center gap-3">
          <RevealContact type="phone" />
        </div>
      </div>
    </div>
  </Section>

  <ServicesGrid />
  <WhyUs />
  <ProcessSteps />
  <AreaCoverage />
  <ContactCta />
</BaseLayout>
