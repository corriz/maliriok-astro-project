---
import Section from '../ui/Section.astro';
---

<Section>
  <div class="rounded-4xl border border-black/5 bg-gradient-to-r from-white to-brand-canvas p-6 shadow-soft md:p-7">
    <h2 class="text-2xl font-black md:text-3xl">Kde nejčastěji pracujeme</h2>
    <p class="mt-4 max-w-3xl text-lg leading-8 text-black/80">
      Nejčastěji zajišťujeme malířské a natěračské práce pro Přerovsko. Podle typu zakázky se domlouváme i
      na širším okolí v rámci Olomouckého kraje.
    </p>
    <div class="mt-5 flex flex-wrap gap-3">
      <span class="rounded-full bg-brand-blue px-4 py-2 text-sm font-semibold text-white">Přerovsko</span>
      <span class="rounded-full bg-brand-yellow px-4 py-2 text-sm font-semibold text-brand-ink">Olomoucký kraj</span>
    </div>
  </div>
</Section>
