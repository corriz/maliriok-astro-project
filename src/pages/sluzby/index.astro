---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageIntro from '../../components/ui/PageIntro.astro';
import Section from '../../components/ui/Section.astro';
import Card from '../../components/ui/Card.astro';
import Button from '../../components/ui/Button.astro';
import { seo } from '../../data/seo';
import { services } from '../../data/services';
---

<BaseLayout title={seo.services.title} description={seo.services.description}>
  <PageIntro
    eyebrow="Přehled služeb"
    title="Služby"
    text="Provádíme malířské, natěračské, fasádní a drobné zednické práce pro byty, domy i firemní prostory."
  />

  <Section>
    <div class="grid gap-6 md:grid-cols-2">
      {services.map((service) => (
        <Card>
          <h2 class="text-2xl font-black">{service.title}</h2>
          <p class="mt-4 text-black/70">{service.description}</p>
          <ul class="mt-5 space-y-2 text-black/80">
            {service.bullets.map((bullet) => (
              <li>• {bullet}</li>
            ))}
          </ul>
          <div class="mt-6">
            <Button href={service.href}>Zjistit více</Button>
          </div>
        </Card>
      ))}
    </div>
  </Section>
</BaseLayout>
