---
import Button from '../ui/Button.astro';
---

<form id="form" action="/api/contact" method="POST" class="card-soft space-y-5">
  <div>
    <label for="name" class="mb-2 block text-sm font-semibold">Jméno</label>
    <input id="name" name="name" required class="w-full rounded-2xl border border-black/10 bg-brand-warm px-4 py-3" placeholder="Vaše jméno" />
  </div>

  <div>
    <label for="contact" class="mb-2 block text-sm font-semibold">Telefon nebo e-mail</label>
    <input id="contact" name="contact" required class="w-full rounded-2xl border border-black/10 bg-brand-warm px-4 py-3" placeholder="Telefon nebo e-mail" />
  </div>

  <div>
    <label for="location" class="mb-2 block text-sm font-semibold">Město nebo obec</label>
    <input id="location" name="location" class="w-full rounded-2xl border border-black/10 bg-brand-warm px-4 py-3" placeholder="Město nebo obec" />
  </div>

  <div>
    <label for="message" class="mb-2 block text-sm font-semibold">Co potřebujete</label>
    <textarea id="message" name="message" rows="6" required class="w-full rounded-2xl border border-black/10 bg-brand-warm px-4 py-3" placeholder="Napište stručně, s čím potřebujete pomoct"></textarea>
  </div>

  <div class="hidden" aria-hidden="true">
    <label for="company">Company</label>
    <input id="company" name="company" tabindex="-1" autocomplete="off" />
  </div>

  <p class="text-sm text-black/60">Odesláním formuláře souhlasíte se zpracováním údajů pro vyřízení poptávky.</p>

  <Button type="submit">Poslat poptávku</Button>
</form>
