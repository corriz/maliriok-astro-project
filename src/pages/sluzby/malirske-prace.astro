---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageIntro from '../../components/ui/PageIntro.astro';
import Section from '../../components/ui/Section.astro';
import Button from '../../components/ui/Button.astro';
import { seo } from '../../data/seo';
---

<BaseLayout title={seo.painting.title} description={seo.painting.description}>
  <PageIntro title="Malířské práce" text="Vymalujeme byt, dům, kancelář i společné prostory. Pracujeme pečlivě, čistě a podle domluvy." />
  <Section>
    <div class="grid gap-8 md:grid-cols-[1.3fr_0.7fr]">
      <div class="card-soft">
        <h2 class="text-2xl font-black">Co děláme</h2>
        <ul class="mt-5 space-y-3 text-black/80">
          <li>• výmalba pokojů</li>
          <li>• výmalba bytů a domů</li>
          <li>• výmalba kanceláří</li>
          <li>• malba stěn a stropů</li>
          <li>• příprava povrchů před malbou</li>
        </ul>
        <p class="mt-6 text-black/70">Každý prostor je jiný. Proto vždy záleží na domluvě a konkrétním stavu stěn.</p>
      </div>
      <div class="card-soft">
        <h2 class="text-2xl font-black">Kontakt</h2>
        <p class="mt-4 text-black/70">Chcete nezávazně domluvit malování? Ozvěte se nám.</p>
        <div class="mt-6"><Button href="/kontakt">Zavolat nám</Button></div>
      </div>
    </div>
  </Section>
</BaseLayout>
