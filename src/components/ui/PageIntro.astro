---
interface Props {
  eyebrow?: string;
  title: string;
  text?: string;
}

const { eyebrow, title, text } = Astro.props;
---

<section class="container-site pb-4 pt-8 md:pb-6 md:pt-10">
  {eyebrow && (
    <div class="mb-3 inline-flex rounded-full bg-brand-yellow/25 px-3 py-1.5 text-xs font-semibold text-brand-ink">
      {eyebrow}
    </div>
  )}
  <h1 class="max-w-4xl text-3xl font-black leading-tight md:text-5xl">{title}</h1>
  {text && <p class="mt-4 max-w-3xl text-base text-black/75 md:text-lg">{text}</p>}
</section>
